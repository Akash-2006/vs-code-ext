{
  "name": "snippets-manager",
  "displayName": "Snippets Manager",
  "description": "Browse, search, insert, and copy user snippets from the sidebar.",
  "version": "1.0.0",
  "publisher": "snippets-manager",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:snippetsManagerView",
    "onCommand:snippets-manager.searchSnippets",
    "onCommand:snippets-manager.refreshSnippets",
    "onCommand:snippets-manager.insertSnippet",
    "onCommand:snippets-manager.copySnippet"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "snippets-manager-sidebar",
          "title": "Snippets",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "snippets-manager-sidebar": [
        {
          "type": "webview",
          "id": "snippetsManagerView",
          "name": "Library",
          "contextualTitle": "Snippets Manager"
        }
      ]
    },
    "commands": [
      {
        "command": "snippets-manager.insertSnippet",
        "title": "Insert Snippet",
        "category": "Snippets Manager"
      },
      {
        "command": "snippets-manager.copySnippet",
        "title": "Copy Snippet",
        "category": "Snippets Manager"
      },
      {
        "command": "snippets-manager.searchSnippets",
        "title": "Search Snippets",
        "category": "Snippets Manager"
      },
      {
        "command": "snippets-manager.refreshSnippets",
        "title": "Refresh Snippets",
        "category": "Snippets Manager"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "snippets-manager.refreshSnippets",
          "when": "view == snippetsManagerView",
          "group": "navigation"
        },
        {
          "command": "snippets-manager.searchSnippets",
          "when": "view == snippetsManagerView",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "snippets-manager.searchSnippets",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pack": "vsce package --no-dependencies --allow-missing-repository --skip-license --allow-package-all-secrets --allow-package-env-file"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.3"
  }
}
